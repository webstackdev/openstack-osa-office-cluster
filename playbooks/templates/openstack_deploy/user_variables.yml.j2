---
# OpenStack-Ansible User Variables (global overrides)
# Deployed to /etc/openstack_deploy/user_variables.yml

# ============================================================================
# Installation method
# ============================================================================
install_method: source

# ============================================================================
# Neutron / OVN networking
# ============================================================================
neutron_plugin_type: ml2.ovn
neutron_ml2_drivers_type: "geneve,flat,vlan"
# neutron_provider_networks is auto-generated by the openstack.osa.provider_networks
# module from the provider_networks entries in openstack_user_config.yml.
# Do NOT override it here — that would skip the module and lose network_mappings.

# ============================================================================
# HAProxy / SSL
# ============================================================================
# Self-signed certificates via OSA's built-in PKI
haproxy_ssl: true
haproxy_ssl_self_signed_regen: false

# Single-node HAProxy — no keepalived
haproxy_use_keepalived: false

# Tell all OpenStack services that endpoints are behind SSL
openstack_service_publicuri_proto: https
openstack_service_internaluri_proto: https
openstack_service_adminuri_proto: https

# The internal repo server (port 8181) is plain HTTP — not behind HAProxy SSL
openstack_repo_protocol: http

# Nova metadata API (port 8775) HAProxy frontend is plain HTTP — override the
# https default inherited from openstack_service_internaluri_proto
nova_metadata_protocol: http

# ============================================================================
# Glance (Image service)
# ============================================================================
# Local file storage on cloud-4core /dev/sda (mounted at /var/lib/glance/images)
glance_default_store: file

# ============================================================================
# Nova (Compute)
# ============================================================================
# CPU overcommit — generous for a home lab
nova_cpu_allocation_ratio: 4.0
nova_ram_allocation_ratio: 1.5

# Explicitly enable noVNC console proxy for HAProxy.
# The default Jinja expression computes this from compute-node architecture
# facts, which are unavailable when running the haproxy playbook alone.
nova_console_proxy_types:
  - novnc

# ============================================================================
# Cinder (Block Storage)
# ============================================================================
# LVM backend on cloud-eugene
cinder_default_volume_type: lvm

# ============================================================================
# Swift (Object Storage)
# ============================================================================
# The os_swift role reads from the `swift` dict — NOT individual swift_* vars.
swift:
  part_power: 10
  repl_number: 1
  min_part_hours: 1
  storage_network: "br-storage"
  replication_network: "br-storage"
  drives:
    - name: sdc
    - name: sdd
  mount_point: /srv
  storage_policies:
    - policy:
        name: default
        index: 0
        repl_number: 1
        default: true

# Override the default replication number (3) for account/container rings
swift_default_replication_number: 1

# ============================================================================
# Barbican (Key Manager) integration
# ============================================================================
# Use Barbican for Cinder volume encryption keys
cinder_service_key_manager: barbican

# Use Barbican for Nova ephemeral disk encryption keys
nova_service_key_manager: barbican

# ============================================================================
# Horizon (Dashboard)
# ============================================================================
# Session timeout: 8 hours (default is 1800 = 30 minutes)
horizon_session_timeout: 28800

# Enable Barbican UI plugin (secrets management panel)
# Heat dashboard auto-enables when heat_all group exists — no explicit setting needed
horizon_enable_barbican_ui: true

# ============================================================================
# LXC container networking
# ============================================================================
# The lab network has no IPv6 route to the internet. Without this, containers
# try IPv6 first for git clones / pip downloads and fail with
# "Network is unreachable". Set gai.conf to prefer IPv4.
lxc_container_commands: |
  if ! grep -q '^precedence ::ffff:0:0/96' /etc/gai.conf 2>/dev/null; then
    echo 'precedence ::ffff:0:0/96  100' >> /etc/gai.conf
  fi

# ============================================================================
# LXC container image
# ============================================================================
# The host has third-party apt repos (Docker, etc.) that get copied into the
# LXC image chroot. Remove them before apt-get update to avoid GPG key errors.
lxc_cache_prep_pre_commands: |
  find /etc/apt/sources.list.d/ -type f \
    ! -name 'ubuntu.sources' \
    ! -name 'uca.sources' \
    ! -name 'cloudarchive-*.list' \
    -delete

# ============================================================================
# RabbitMQ repos
# ============================================================================
# The default ppa1.rabbitmq.com domain is defunct; use the new deb1 mirrors.
rabbitmq_repo_url: "https://deb1.rabbitmq.com/rabbitmq-server/ubuntu/noble"
rabbitmq_erlang_repo_url: "https://deb1.rabbitmq.com/rabbitmq-erlang/ubuntu/noble"

# ============================================================================
# LXC container SSH key
# ============================================================================
# OSA injects this public key into containers for root access
lxc_container_ssh_key: /root/.ssh/id_rsa.pub

# NOTE: ansible_user, ansible_become, and ansible_ssh_private_key_file are set
# in group_vars/ (not here) because user_variables.yml is loaded as extra vars
# (-e @) which would override group-level overrides for containers.

# ============================================================================
# Designate (DNS)
# ============================================================================
# BIND9 pool configuration — single nameserver in the Designate container
designate_pools_yaml:
  - name: "default"
    description: "Default BIND9 Pool"
    attributes: {}
    ns_records:
      - hostname: "ns1.home.cloud."
        priority: 1
    nameservers:
      - host: 127.0.0.1
        port: 53
    targets:
      - type: bind9
        description: "BIND9 on cloud-4core"
        masters:
          - host: 127.0.0.1
            port: 5354
        options:
          host: 127.0.0.1
          port: 53
          rndc_host: 127.0.0.1
          rndc_port: 953
          rndc_key_file: /etc/designate/rndc.key

# rndc key for BIND9 authentication
designate_rndc_keys:
  - name: "rndc-key"
    file: /etc/designate/rndc.key
    algorithm: "hmac-sha256"
    secret: "HalkP9PWONDtxfSEWsqYqXMxJbnc7JpgPzTUcOmpHkw="

# Neutron DNS integration — auto-create records for instances/ports
neutron_plugin_base:
  - ovn-router
  - dns
neutron_dns_domain: "home.cloud."

# ============================================================================
# Trove (Database as a Service)
# ============================================================================
# Guest agent RabbitMQ addresses — guest VMs on dbaas_service_net (flat
# provider network on br-mgmt / mgmtnet) can reach the RabbitMQ container
# directly at its management IP.
trove_guest_oslomsg_rpc_servers: "192.168.50.82"
trove_guest_oslomsg_notify_servers: "192.168.50.82"
# Skip the provider network interface lookup — RabbitMQ is on eth1 (br-mgmt)
trove_provider_net_iface: "eth1"

# Management network + security group for guest agent ↔ RabbitMQ traffic
# Work around Trove bug: clients_admin.py derives cinder client version from
# cinder_service_type via .split('v')[-1]. With the modern 'block-storage'
# service type this yields 'block-storage' (no 'v' to split on). Setting
# 'volumev3' makes it parse to version '3', and keystoneauth aliases it back
# to 'block-storage' for endpoint discovery.
trove_config_overrides:
  DEFAULT:
    management_networks: "c1c43d25-4bc2-4f13-9f37-69e9f58dab9a"
    management_security_groups: "e86996f0-5e99-4269-8784-832ace5e1c3f"
    # Ensure guest VMs get full network metadata (both user + management NICs)
    # via config drive instead of relying on the metadata service.
    use_nova_server_config_drive: "True"
    cinder_service_type: "volumev3"
    # Fix: DesignateDriver was renamed to DesignateDriverV2 in 2025.2
    dns_driver: "trove.dns.designate.driver.DesignateDriverV2"
    # Disable Trove's built-in DNS integration — it has auth bugs (passes
    # project name as project_id). Neutron+Designate integration handles
    # instance DNS records via the dns_domain setting instead.
    trove_dns_support: "False"
    use_journal: false
    use_stderr: false
    log_dir: /var/log/trove

# Datastore definitions — MariaDB 11.4 and PostgreSQL 17
trove_datastores:
  mariadb:
    - name: MariaDB
      versions:
        - name: "11.4"
          enabled: true
          version-number: "11.4"
          default: true
  postgresql:
    - name: PostgreSQL
      versions:
        - name: "17"
          enabled: true
          version-number: "17"
          default: true

# ============================================================================
# Octavia (Load Balancer)
# ============================================================================
# Single amphora topology (no HA pair) — sufficient for a home lab
octavia_loadbalancer_topology: SINGLE
# Disable anti-affinity (only 1 amphora per LB in SINGLE mode)
octavia_enable_anti_affinity: false
# Management network — VLAN 232 on br-storage
octavia_provider_network_type: vlan
octavia_provider_segmentation_id: 232
octavia_management_net_subnet_cidr: 172.29.232.0/22
octavia_management_net_subnet_allocation_pools: "172.29.232.10-172.29.235.200"
# Default LB provider — amphorav2 for L7 support; tenants can request
# ovn provider explicitly with: --provider ovn
octavia_default_provider_driver: amphorav2
# Service project quotas — sized for upcoming 3×16C/64GB hardware upgrade
_max_amphora_instances: 50
openstack_user_identity:
  quotas:
    - name: "service"
      cores: "{{ '{{' }} _max_amphora_instances {{ '}}' }}"
      ram: "{{ '{{' }} (_max_amphora_instances | int) * 1024 {{ '}}' }}"
      instances: "{{ '{{' }} _max_amphora_instances {{ '}}' }}"
      port: "{{ '{{' }} (_max_amphora_instances | int) * 10 {{ '}}' }}"
      server_groups: "{{ '{{' }} ((_max_amphora_instances | int) * 0.5) | int | abs {{ '}}' }}"
      server_group_members: 50
      security_group: "{{ '{{' }} (_max_amphora_instances | int) * 1.5 | int | abs {{ '}}' }}"
      security_group_rule: "{{ '{{' }} ((_max_amphora_instances | int) * 1.5 | int | abs) * 100 {{ '}}' }}"

# ============================================================================
# uWSGI / API worker tuning
# ============================================================================
# OSA defaults to min(vcpus * 2, 16) workers per service, which on cloud-4core
# (8 threads) yields 16 workers each — far too many for a home lab with ~34 qps
# total. These overrides free ~7 GB RAM on the controller node.
neutron_wsgi_processes: 4
nova_wsgi_processes: 4
keystone_wsgi_processes: 4
heat_wsgi_processes: 4
placement_wsgi_processes: 4
zun_wsgi_processes: 2
octavia_wsgi_processes: 2
trove_api_workers: 2
trove_conductor_workers: 2
magnum_wsgi_processes: 2
magnum_conductor_workers: 2

# ============================================================================
# Zun (Container as a Service)
# ============================================================================
# Compute nodes shared with Nova — both manage workloads on the same hosts
zun_zun_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/zun
  compute:
    host_shared_with_nova: true

# Disable Kata Containers — use runc for container runtime.
# Kata dedicates resources per container (own kernel, pinned memory) which is
# excessive for a resource-constrained lab. runc shares the host kernel and
# allows overcommit via cgroup scheduling.
zun_kata_enabled: "False"
zun_container_runtime: runc

# Restrict Docker TCP listener to management network only (not 0.0.0.0)
zun_docker_bind_host: "{{ '{{' }} management_address {{ '}}' }}"

# Auto-prune unused Docker images daily to save disk space
zun_docker_prune_images: true
zun_docker_prune_frequency: day

# ============================================================================
# Ceilometer / Gnocchi (Telemetry)
# ============================================================================
# Use Swift for Gnocchi metric storage (already deployed on cloud-eugene)
gnocchi_storage_driver: swift

# ============================================================================
# Magnum (Container Infrastructure Management / Kubernetes as a Service)
# ============================================================================
# Use Barbican for cluster TLS certificate storage (we have it deployed)
magnum_cert_manager_type: barbican

# Inject the OSA self-signed root CA into Magnum VMs so heat-container-agent
# can verify TLS connections to Heat/Keystone endpoints (which sit behind
# HAProxy with self-signed certs). HAProxy presents the server cert +
# intermediate CA in the TLS handshake, so VMs only need the root CA to
# complete the chain. OSA's PKI management deploys this root CA to all
# containers at /usr/local/share/ca-certificates/.
magnum_config_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/magnum
  drivers:
    openstack_ca_file: /usr/local/share/ca-certificates/ExampleCorpRoot.crt

# ============================================================================
# Logging: switch containerized services from journal to file-based logging
# ============================================================================
# OSA 2025.2 hardcodes use_journal=True in every os_* role template. But
# Promtail only scrapes file logs from LXC containers (not container journals).
# These overrides switch each service to file logging so Promtail picks them up
# via the lxc_containers glob: /var/lib/lxc/*/rootfs/var/log/**/*.log
#
# NOTE: Only containerized services on cloud-4core need this. Host-level
# services (cinder-volume, nova-compute, kuryr-libnetwork, neutron-ovn-
# metadata-agent) already reach Loki via the host journal scraper.

cinder_cinder_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/cinder

nova_nova_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/nova

neutron_neutron_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/neutron

keystone_keystone_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/keystone

glance_glance_api_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/glance

heat_heat_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/heat

octavia_octavia_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/octavia

placement_placement_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/placement

barbican_config_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/barbican

designate_designate_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/designate

aodh_aodh_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/aodh

ceilometer_ceilometer_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/ceilometer

gnocchi_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/gnocchi

manila_manila_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/manila

mistral_mistral_conf_overrides:
  DEFAULT:
    use_journal: false
    use_stderr: false
    log_dir: /var/log/mistral

# Galera: enable file-based error logging (MariaDB defaults to journal-only)
galera_my_cnf_overrides:
  mysqld:
    log_error: /var/log/mysql/error.log

# ============================================================================
# Security hardening (ansible-hardening role)
# ============================================================================
# Override STIG V-72241 default (ClientAliveCountMax 0) which kills SSH
# sessions after a single missed keepalive. Use a reasonable value instead.
security_sshd_client_alive_interval: 60
security_sshd_client_alive_count_max: 3
# Disable STIG V-72223 shell idle timeout (TMOUT=600 in /etc/profile).
# Set to 0 to prevent the hardening role from adding it.
security_rhel7_session_timeout: 0
