---
# OpenStack-Ansible User Variables (global overrides)
# Deployed to /etc/openstack_deploy/user_variables.yml

# ============================================================================
# Installation method
# ============================================================================
install_method: source

# ============================================================================
# Neutron / OVN networking
# ============================================================================
neutron_plugin_type: ml2.ovn
neutron_ml2_drivers_type: "geneve,flat"
neutron_provider_networks:
  network_types: "geneve,flat"
  network_geneve_ranges: "1:1000"
  network_flat_networks: "physnet1"

# ============================================================================
# HAProxy / SSL
# ============================================================================
# Self-signed certificates via OSA's built-in PKI
haproxy_ssl: true
haproxy_ssl_self_signed_regen: false

# Single-node HAProxy — no keepalived
haproxy_use_keepalived: false

# Tell all OpenStack services that endpoints are behind SSL
openstack_service_publicuri_proto: https
openstack_service_internaluri_proto: https
openstack_service_adminuri_proto: https

# The internal repo server (port 8181) is plain HTTP — not behind HAProxy SSL
openstack_repo_protocol: http

# ============================================================================
# Glance (Image service)
# ============================================================================
# Local file storage on cloud-4core /dev/sda (mounted at /var/lib/glance/images)
glance_default_store: file

# ============================================================================
# Nova (Compute)
# ============================================================================
# CPU overcommit — generous for a home lab
nova_cpu_allocation_ratio: 4.0
nova_ram_allocation_ratio: 1.5

# Explicitly enable noVNC console proxy for HAProxy.
# The default Jinja expression computes this from compute-node architecture
# facts, which are unavailable when running the haproxy playbook alone.
nova_console_proxy_types:
  - novnc

# ============================================================================
# Cinder (Block Storage)
# ============================================================================
# LVM backend on cloud-eugene
cinder_default_volume_type: lvm

# ============================================================================
# Swift (Object Storage)
# ============================================================================
# The os_swift role reads from the `swift` dict — NOT individual swift_* vars.
swift:
  part_power: 10
  repl_number: 1
  min_part_hours: 1
  storage_network: "br-storage"
  replication_network: "br-storage"
  drives:
    - name: sdc
    - name: sdd
  mount_point: /srv
  storage_policies:
    - policy:
        name: default
        index: 0
        repl_number: 1
        default: true

# Override the default replication number (3) for account/container rings
swift_default_replication_number: 1

# ============================================================================
# Barbican (Key Manager) integration
# ============================================================================
# Use Barbican for Cinder volume encryption keys
cinder_service_key_manager: barbican

# Use Barbican for Nova ephemeral disk encryption keys
nova_service_key_manager: barbican

# ============================================================================
# Horizon (Dashboard)
# ============================================================================
# Session timeout: 8 hours (default is 1800 = 30 minutes)
horizon_session_timeout: 28800

# Enable Barbican UI plugin (secrets management panel)
# Heat dashboard auto-enables when heat_all group exists — no explicit setting needed
horizon_enable_barbican_ui: true

# ============================================================================
# LXC container networking
# ============================================================================
# The lab network has no IPv6 route to the internet. Without this, containers
# try IPv6 first for git clones / pip downloads and fail with
# "Network is unreachable". Set gai.conf to prefer IPv4.
lxc_container_commands: |
  if ! grep -q '^precedence ::ffff:0:0/96' /etc/gai.conf 2>/dev/null; then
    echo 'precedence ::ffff:0:0/96  100' >> /etc/gai.conf
  fi

# ============================================================================
# LXC container image
# ============================================================================
# The host has third-party apt repos (Docker, etc.) that get copied into the
# LXC image chroot. Remove them before apt-get update to avoid GPG key errors.
lxc_cache_prep_pre_commands: |
  find /etc/apt/sources.list.d/ -type f \
    ! -name 'ubuntu.sources' \
    ! -name 'uca.sources' \
    ! -name 'cloudarchive-*.list' \
    -delete

# ============================================================================
# RabbitMQ repos
# ============================================================================
# The default ppa1.rabbitmq.com domain is defunct; use the new deb1 mirrors.
rabbitmq_repo_url: "https://deb1.rabbitmq.com/rabbitmq-server/ubuntu/noble"
rabbitmq_erlang_repo_url: "https://deb1.rabbitmq.com/rabbitmq-erlang/ubuntu/noble"

# ============================================================================
# LXC container SSH key
# ============================================================================
# OSA injects this public key into containers for root access
lxc_container_ssh_key: /root/.ssh/id_rsa.pub

# NOTE: ansible_user, ansible_become, and ansible_ssh_private_key_file are set
# in group_vars/ (not here) because user_variables.yml is loaded as extra vars
# (-e @) which would override group-level overrides for containers.

# ============================================================================
# Designate (DNS)
# ============================================================================
# BIND9 pool configuration — single nameserver in the Designate container
designate_pools_yaml:
  - name: "default"
    description: "Default BIND9 Pool"
    attributes: {}
    ns_records:
      - hostname: "ns1.home.cloud."
        priority: 1
    nameservers:
      - host: 127.0.0.1
        port: 53
    targets:
      - type: bind9
        description: "BIND9 on cloud-4core"
        masters:
          - host: 127.0.0.1
            port: 5354
        options:
          host: 127.0.0.1
          port: 53
          rndc_host: 127.0.0.1
          rndc_port: 953
          rndc_key_file: /etc/designate/rndc.key

# rndc key for BIND9 authentication
designate_rndc_keys:
  - name: "rndc-key"
    file: /etc/designate/rndc.key
    algorithm: "hmac-sha256"
    secret: "HalkP9PWONDtxfSEWsqYqXMxJbnc7JpgPzTUcOmpHkw="

# Neutron DNS integration — auto-create records for instances/ports
neutron_plugin_base:
  - ovn-router
  - dns
neutron_dns_domain: "home.cloud."

# ============================================================================
# Trove (Database as a Service)
# ============================================================================
# Guest agent RabbitMQ addresses — override the default provider-network
# lookup since we don't have a separate dbaas-mgmt bridge. RabbitMQ is on
# cloud-4core's management IP.
trove_guest_oslomsg_rpc_servers: "192.168.50.168"
trove_guest_oslomsg_notify_servers: "192.168.50.168"
# Skip the provider network interface lookup — RabbitMQ is on eth1 (br-mgmt)
trove_provider_net_iface: "eth1"

# Management network + security group for guest agent ↔ RabbitMQ traffic
trove_config_overrides:
  DEFAULT:
    management_networks: "95bbef9f-c2e5-493d-a669-b2f928c933af"
    management_security_groups: "e86996f0-5e99-4269-8784-832ace5e1c3f"

# Datastore definitions — MariaDB 11.4 and PostgreSQL 17
trove_datastores:
  mariadb:
    - name: MariaDB
      versions:
        - name: "11.4"
          enabled: true
          version-number: "11.4"
          default: true
  postgresql:
    - name: PostgreSQL
      versions:
        - name: "17"
          enabled: true
          version-number: "17"
          default: true
