---
# OpenStack-Ansible User Variables (global overrides)
# Deployed to /etc/openstack_deploy/user_variables.yml

# ============================================================================
# Installation method
# ============================================================================
install_method: source

# ============================================================================
# Neutron / OVN networking
# ============================================================================
neutron_plugin_type: ml2.ovn
neutron_ml2_drivers_type: "geneve,flat"
neutron_provider_networks:
  network_types: "geneve,flat"
  network_geneve_ranges: "1:1000"
  network_flat_networks: "physnet1"

# ============================================================================
# HAProxy / SSL
# ============================================================================
# Self-signed certificates via OSA's built-in PKI
haproxy_ssl: true
haproxy_ssl_self_signed_regen: false

# Single-node HAProxy — no keepalived
haproxy_use_keepalived: false

# ============================================================================
# Glance (Image service)
# ============================================================================
# Local file storage on cloud-4core /dev/sda (mounted at /var/lib/glance/images)
glance_default_store: file

# ============================================================================
# Nova (Compute)
# ============================================================================
# CPU overcommit — generous for a home lab
nova_cpu_allocation_ratio: 4.0
nova_ram_allocation_ratio: 1.5

# ============================================================================
# Cinder (Block Storage)
# ============================================================================
# LVM backend on cloud-eugene
cinder_default_volume_type: lvm

# ============================================================================
# Swift (Object Storage)
# ============================================================================
# Swift storage policies
swift_storage_policies:
  - policy:
      name: default
      index: 0
      default: yes

# Swift ring power and replicas (single storage node = 1 replica)
swift_part_power: 10
swift_replicas: 1
swift_min_part_hours: 1

# ============================================================================
# LXC container image
# ============================================================================
# The host has third-party apt repos (Docker, etc.) that get copied into the
# LXC image chroot. Remove them before apt-get update to avoid GPG key errors.
lxc_cache_prep_pre_commands: |
  find /etc/apt/sources.list.d/ -type f \
    ! -name 'ubuntu.sources' \
    ! -name 'uca.sources' \
    ! -name 'cloudarchive-*.list' \
    -delete

# ============================================================================
# LXC container SSH key
# ============================================================================
# OSA injects this public key into containers for root access
lxc_container_ssh_key: /root/.ssh/id_rsa.pub

# NOTE: ansible_user, ansible_become, and ansible_ssh_private_key_file are set
# in group_vars/ (not here) because user_variables.yml is loaded as extra vars
# (-e @) which would override group-level overrides for containers.
