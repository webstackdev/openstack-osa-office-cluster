  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Telemetry Log Volume",
      "description": "Log lines per second from Gnocchi and Ceilometer containers",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by(container) (rate({job=\"openstack\", container=~\".*gnocchi.*|.*ceilometer.*|.*aodh.*|.*mistral.*\"} [$__auto]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Telemetry Errors",
      "description": "Error-level log lines from Gnocchi and Ceilometer",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by(container) (rate({job=\"openstack\", container=~\".*gnocchi.*|.*ceilometer.*|.*aodh.*|.*mistral.*\"} |~ \"(?i)ERROR\" [$__auto]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Gnocchi API (8041)",
      "description": "Gnocchi API container log activity — non-zero means the service is running and logging",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No logs", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"openstack\", container=~\".*gnocchi.*\"} [5m])",
          "legendFormat": "gnocchi",
          "refId": "A"
        }
