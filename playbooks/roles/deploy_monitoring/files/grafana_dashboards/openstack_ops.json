  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Error Rate by Service",
      "description": "ERROR log lines per second across all OpenStack services",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by(container) (rate({job=\"openstack\", container=~\"$container\"} |= \"ERROR\" [$__auto]))",
          "legendFormat": "{{ container }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Error Log Stream",
      "description": "All ERROR-level logs from OpenStack services",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"openstack\", container=~\"$container\"} |= \"ERROR\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "HAProxy",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HAProxy Request Rate by Frontend",
      "description": "Requests per second by HAProxy frontend",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by(frontend) (rate({job=\"haproxy\"} | regexp `\\S+ \\S+ (?P<frontend>\\S+)` [$__auto]))",
          "legendFormat": "{{ frontend }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HAProxy 5xx Errors",
      "description": "HTTP 5xx responses (Gateway Timeout, Bad Gateway, etc.)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by(frontend) (rate({job=\"haproxy\"} | regexp `\\S+ \\S+ (?P<frontend>\\S+)` | regexp `HTTP/\\d\\.\\d\" (?P<status>\\d+)` | status >= 500 [$__auto]))",
          "legendFormat": "{{ frontend }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "HAProxy 5xx Log Stream",
      "description": "All HAProxy log lines with HTTP 5xx status codes",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"haproxy\"} |~ ` 5\\d{2} `",
          "refId": "A"
        }
      ]
    },
