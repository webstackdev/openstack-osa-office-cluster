server:
  http_listen_port: {{ deploy_monitoring_promtail_http_port }}
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ deploy_monitoring_loki_push_url }}

scrape_configs:
  - job_name: syslog
    static_configs:
      - targets:
          - localhost
        labels:
          job: syslog
          host: {{ short_hostname }}
          __path__: /var/log/syslog

  - job_name: journal
    journal:
      labels:
        job: journal
        host: {{ short_hostname }}
    relabel_configs:
      - source_labels: ['__journal__systemd_unit']
        target_label: unit
{% if is_controller | default(false) %}

  - job_name: haproxy
    static_configs:
      - targets:
          - localhost
        labels:
          job: haproxy
          host: {{ short_hostname }}
          __path__: /var/log/haproxy.log

  - job_name: lxc_containers
    static_configs:
      - targets:
          - localhost
        labels:
          job: openstack
          host: {{ short_hostname }}
          __path__: /openstack/log/*/**/*.log
    pipeline_stages:
      - match:
          selector: '{job="openstack"}'
          stages:
            - regex:
                source: filename
                expression: '/openstack/log/(?P<container>[^/]+)/(?P<logpath>.+)'
            - labels:
                container:
                logpath:

  - job_name: docker_containers
    static_configs:
      - targets:
          - localhost
        labels:
          job: docker
          host: {{ short_hostname }}
          __path__: /var/lib/docker/containers/**/*-json.log
    pipeline_stages:
      - docker: {}
{% endif %}
{% if is_compute | default(false) %}

  - job_name: nova_compute
    static_configs:
      - targets:
          - localhost
        labels:
          job: nova-compute
          host: {{ short_hostname }}
          __path__: /var/log/nova/**/*.log

  - job_name: ovn
    static_configs:
      - targets:
          - localhost
        labels:
          job: ovn
          host: {{ short_hostname }}
          __path__: /var/log/ovn/**/*.log

  - job_name: openvswitch
    static_configs:
      - targets:
          - localhost
        labels:
          job: openvswitch
          host: {{ short_hostname }}
          __path__: /var/log/openvswitch/**/*.log
{% endif %}
