global:
  scrape_interval: {{ deploy_monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ deploy_monitoring_prometheus_scrape_interval }}

scrape_configs:
  - job_name: node
    static_configs:
{% for target in deploy_monitoring_prometheus_node_targets %}
      - targets:
          - "{{ target.address }}"
        labels:
          hostname: "{{ target.hostname }}"
{% endfor %}
    relabel_configs:
      - source_labels: [hostname]
        target_label: instance

  - job_name: prometheus
    static_configs:
      - targets:
          - "{{ deploy_monitoring_prometheus_listen_address }}:{{ deploy_monitoring_prometheus_http_port }}"
